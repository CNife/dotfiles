{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "model": "alibaba-coding-plan-cn/qwen3.6-plus",
  "small_model": "alibaba-coding-plan-cn/glm-4.7",
  "mcp": {
    "jina": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.jina.ai/sse",
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/.secret/jina.api-key}",
      },
    },
    "markitdown": {
      "enabled": true,
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp",
      ],
    }
  },
  "lsp": {
    "rumdl": {
      "command": [
        "rumdl",
        "server"
      ],
      "extensions": [
        ".md",
        ".markdown",
        ".mdx",
        ".qmd"
      ],
    },
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      // 基础文件操作
      "cat *": "allow",
      "cd *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "file *": "allow",
      "realpath *": "allow",
      "basename *": "allow",
      "dirname *": "allow",
      "readlink *": "allow",
      "mkdir *": "allow",
      // 文件查找与搜索
      "find *": "allow",
      "grep *": "allow",
      "which *": "allow",
      // 文件查看
      "head *": "allow",
      "tail *": "allow",
      // 文件检查
      "test *": "allow",
      "stat *": "allow",
      "tree *": "allow",
      // 磁盘信息
      "df *": "allow",
      "du *": "allow",
      // 文本处理
      "awk *": "allow",
      "echo *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "diff *": "allow",
      // 数据处理
      "jq *": "allow",
      // 系统信息
      "uname *": "allow",
      "hostname *": "allow",
      "free *": "allow",
      "whoami *": "allow",
      "id *": "allow",
      "fastfetch *": "allow",
      "ps *": "allow",
      "pgrep *": "allow",
      "sleep *": "allow",
      // 网络只读
      "curl *": "allow",
      "wget *": "allow",
      "ping *": "allow",
      // Git 只读
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "git rev-parse *": "allow",
      // 开发工具
      "ruff *": "allow",
      "rumdl *": "allow",
      "shellcheck *": "allow",
      // OpenCode 相关
      "opencode *": "allow",
      "npx skills find *": "allow",
      // 浏览器自动化
      "agent-browser *": "allow",
      // Python / uv
      "uv sync *": "allow",
      "uv add *": "allow",
      "uv run pytest *": "allow",
      "uv run ruff *": "allow",
    },
  },
  "plugin": [
    "oh-my-openagent@3.17.1"
  ],
}

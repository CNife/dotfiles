{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "model": "deepseek/deepseek-v4-pro",
  "small_model": "alibaba-coding-plan-cn/qwen3.5-plus",
  "mcp": {
    "jina": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.jina.ai/v1",
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/.secret/jina.api-key}",
      },
    },
    "paddleocr": {
      "enabled": false,
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "paddleocr-mcp",
        "paddleocr_mcp"
      ],
      "environment": {
        "PADDLEOCR_MCP_PIPELINE": "PaddleOCR-VL",
        "PADDLEOCR_MCP_PPOCR_SOURCE": "aistudio",
        "PADDLEOCR_MCP_SERVER_URL": "https://f3kbm7o0k2k14dn9.aistudio-app.com",
        "PADDLEOCR_MCP_AISTUDIO_ACCESS_TOKEN": "{file:~/.config/opencode/.secret/paddle.api-key}",
      },
    },
  },
  "tools": {
    "jina_search_images": false,
    "jina_classify_text": false,
    "jina_sort_by_relevance": false,
    "jina_deduplicate_strings": false,
    "jina_deduplicate_images": false,
    "jina_guess_datetime_url": false,
    "jina_capture_screenshot_url": false,
    "jina_show_api_key": false,
  },
  "lsp": {
    "rumdl": {
      "command": [
        "rumdl",
        "server"
      ],
      "extensions": [
        ".md",
        ".markdown",
        ".mdx",
        ".qmd"
      ],
    },
  },
  "permission": {
    "edit": "ask",
    "external_directory": {
      "/mnt/c/Obsidian": "allow",
      "/mnt/c/Obsidian/*": "allow",
      "/home/cnife/.config/cnife-skills": "allow",
      "/home/cnife/.config/cnife-skills/*": "allow"
    },
    "bash": {
      "*": "ask",
      // sudo（每次需确认，密码通过 SUDO_ASKPASS 自动提供）
      "sudo *": "ask",
      // 基础文件操作
      "cat *": "allow",
      "cd *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "file *": "allow",
      "realpath *": "allow",
      "basename *": "allow",
      "dirname *": "allow",
      "readlink *": "allow",
      "mkdir *": "allow",
      // 文件查找与搜索
      "find *": "allow",
      "grep *": "allow",
      "which *": "allow",
      // 文件查看
      "head *": "allow",
      "tail *": "allow",
      // 文件检查
      "test *": "allow",
      "stat *": "allow",
      "tree *": "allow",
      // 磁盘信息
      "df *": "allow",
      "du *": "allow",
      // 文本处理
      "awk *": "allow",
      "echo *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "diff *": "allow",
      // 数据处理
      "jq *": "allow",
      // 系统信息
      "uname *": "allow",
      "hostname *": "allow",
      "free *": "allow",
      "whoami *": "allow",
      "id *": "allow",
      "fastfetch *": "allow",
      "ps *": "allow",
      "pgrep *": "allow",
      "sleep *": "allow",
      // 网络只读
      "curl *": "allow",
      "wget *": "allow",
      "ping *": "allow",
      // Git 只读
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "git rev-parse *": "allow",
      // 开发工具
      "rumdl *": "allow",
      "shellcheck *": "allow",
      // OpenCode 相关
      "opencode *": "allow",
      "npx skills find *": "allow",
      // 浏览器自动化
      "agent-browser *": "allow",
      // Python / uv
      "uv sync *": "allow",
      "uv add *": "allow",
      "uv run pytest *": "allow",
      "uv run ruff *": "allow",
      "ruff *": "allow",
      // Obsidian CLI 只读命令
      "obsidian.exe aliases *": "allow",
      "obsidian.exe backlinks *": "allow",
      "obsidian.exe base:query *": "allow",
      "obsidian.exe base:views *": "allow",
      "obsidian.exe bases *": "allow",
      "obsidian.exe bookmarks *": "allow",
      "obsidian.exe commands *": "allow",
      "obsidian.exe daily:path *": "allow",
      "obsidian.exe daily:read *": "allow",
      "obsidian.exe deadends *": "allow",
      "obsidian.exe diff *": "allow",
      "obsidian.exe file *": "allow",
      "obsidian.exe files *": "allow",
      "obsidian.exe folder *": "allow",
      "obsidian.exe folders *": "allow",
      "obsidian.exe help *": "allow",
      "obsidian.exe history *": "allow",
      "obsidian.exe history:list *": "allow",
      "obsidian.exe history:read *": "allow",
      "obsidian.exe hotkey *": "allow",
      "obsidian.exe hotkeys *": "allow",
      "obsidian.exe links *": "allow",
      "obsidian.exe orphans *": "allow",
      "obsidian.exe outline *": "allow",
      "obsidian.exe plugin *": "allow",
      "obsidian.exe plugins *": "allow",
      "obsidian.exe plugins:enabled *": "allow",
      "obsidian.exe properties *": "allow",
      "obsidian.exe property:read *": "allow",
      "obsidian.exe random:read *": "allow",
      "obsidian.exe read *": "allow",
      "obsidian.exe recents *": "allow",
      "obsidian.exe search *": "allow",
      "obsidian.exe search:context *": "allow",
      "obsidian.exe snippets *": "allow",
      "obsidian.exe snippets:enabled *": "allow",
      "obsidian.exe tabs *": "allow",
      "obsidian.exe tag *": "allow",
      "obsidian.exe tags *": "allow",
      "obsidian.exe tasks *": "allow",
      "obsidian.exe templates *": "allow",
      "obsidian.exe template:read *": "allow",
      "obsidian.exe themes *": "allow",
      "obsidian.exe theme *": "allow",
      "obsidian.exe unresolved *": "allow",
      "obsidian.exe vault *": "allow",
      "obsidian.exe vaults *": "allow",
      "obsidian.exe version *": "allow",
      "obsidian.exe wordcount *": "allow",
      "obsidian.exe workspace *": "allow",
      "obsidian.exe dev:console *": "allow",
      "obsidian.exe dev:css *": "allow",
      "obsidian.exe dev:dom *": "allow",
      "obsidian.exe dev:errors *": "allow",
      "kubectl get *": "allow",
      "kubectl describe *": "allow",
      "kubectl logs *": "allow",
      "kubectl top *": "allow",
      "kubectl explain *": "allow",
      "kubectl api-resources *": "allow",
      "kubectl api-versions *": "allow",
      "kubectl cluster-info *": "allow",
      "kubectl config view *": "allow",
      "kubectl version *": "allow",
      "kubectl auth can-i *": "allow",
      "kubectl diff *": "allow",
      "kubectl rollout history *": "allow",
      "opencli list *": "allow",
      "opencli validate *": "allow",
      "opencli verify *": "allow",
      "opencli doctor *": "allow",
      "opencli browser *": "allow",
      "opencli completion *": "allow",
      "opencli plugin *": "allow",
      "opencli adapter *": "allow",
      "opencli daemon *": "allow",
      "chezmoi status *": "allow",
      "chezmoi diff *": "allow",
      "chezmoi managed *": "allow",
      "chezmoi verify *": "allow",
      "chezmoi source-path *": "allow",
      "chezmoi doctor *": "allow",
      "chezmoi git -- status *": "allow",
      "chezmoi git -- log *": "allow",
      "chezmoi git -- remote *": "allow",
      "chezmoi cat *": "allow",
    },
  },
  "plugin": [],
}

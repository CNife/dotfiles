{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "model": "alibaba-coding-plan-cn/qwen3.6-plus",
  "small_model": "alibaba-coding-plan-cn/glm-4.7",
  "mcp": {
    "jina": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.jina.ai/sse",
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/.secret/jina.api-key}",
      },
    },
    "markitdown": {
      "enabled": true,
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp",
      ],
    }
  },
  "lsp": {
    "rumdl": {
      "command": [
        "rumdl",
        "server"
      ],
      "extensions": [
        ".md",
        ".markdown",
        ".mdx",
        ".qmd"
      ],
    },
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      // 基础文件操作
      "cat *": "allow",
      "cd *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "file *": "allow",
      "realpath *": "allow",
      "basename *": "allow",
      "dirname *": "allow",
      "readlink *": "allow",
      "mkdir *": "allow",
      // 文件查找与搜索
      "find *": "allow",
      "locate *": "allow",
      "grep *": "allow",
      "whereis *": "allow",
      "which *": "allow",
      // 文件查看
      "head *": "allow",
      "tail *": "allow",
      "less *": "allow",
      "more *": "allow",
      "nl *": "allow",
      // 文件检查
      "test *": "allow",
      "stat *": "allow",
      "tree *": "allow",
      "cmp *": "allow",
      "comm *": "allow",
      // 磁盘信息
      "df *": "allow",
      "du *": "allow",
      // 文本处理
      "awk *": "allow",
      "echo *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "diff *": "allow",
      // 数据处理
      "jq *": "allow",
      // 系统信息
      "uname *": "allow",
      "hostname *": "allow",
      "uptime *": "allow",
      "free *": "allow",
      "whoami *": "allow",
      "id *": "allow",
      "fastfetch *": "allow",
      "ps *": "allow",
      "pgrep *": "allow",
      "sleep *": "allow",
      // 网络只读
      "curl *": "allow",
      "wget *": "allow",
      "ping *": "allow",
      // 压缩查看
      "tar -t *": "allow",
      "zipinfo *": "allow",
      "unzip -l *": "allow",
      // 哈希校验
      "md5sum *": "allow",
      "sha1sum *": "allow",
      "sha256sum *": "allow",
      // Git 只读
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "git rev-parse *": "allow",
      // GitHub CLI 只读
      "gh auth status": "allow",
      "gh browse * --no-browser *": "allow",
      "gh completion *": "allow",
      "gh help *": "allow",
      "gh --help": "allow",
      "gh --version": "allow",
      "gh status *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh issue status *": "allow",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh pr status *": "allow",
      "gh pr checks *": "allow",
      "gh pr diff *": "allow",
      "gh repo list *": "allow",
      "gh repo view *": "allow",
      "gh repo gitignore *": "allow",
      "gh repo license *": "allow",
      "gh gist list *": "allow",
      "gh gist view *": "allow",
      "gh release list *": "allow",
      "gh release view *": "allow",
      "gh release download *": "allow",
      "gh release verify *": "allow",
      "gh release verify-asset *": "allow",
      "gh workflow list *": "allow",
      "gh workflow view *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow",
      "gh run watch *": "allow",
      "gh run download *": "allow",
      "gh search code *": "allow",
      "gh search commits *": "allow",
      "gh search issues *": "allow",
      "gh search prs *": "allow",
      "gh search repos *": "allow",
      "gh org list *": "allow",
      "gh project list *": "allow",
      "gh project view *": "allow",
      "gh project item-list *": "allow",
      "gh project field-list *": "allow",
      "gh codespace list *": "allow",
      "gh codespace view *": "allow",
      "gh codespace logs *": "allow",
      "gh codespace ports *": "allow",
      "gh cs list *": "allow",
      "gh cs view *": "allow",
      "gh cs logs *": "allow",
      "gh cs ports *": "allow",
      "gh label list *": "allow",
      "gh secret list *": "allow",
      "gh ssh-key list *": "allow",
      "gh gpg-key list *": "allow",
      "gh variable list *": "allow",
      "gh variable get *": "allow",
      "gh ruleset list *": "allow",
      "gh ruleset view *": "allow",
      "gh ruleset check *": "allow",
      "gh rs list *": "allow",
      "gh rs view *": "allow",
      "gh rs check *": "allow",
      "gh cache list *": "allow",
      "gh config list *": "allow",
      "gh config get *": "allow",
      "gh alias list *": "allow",
      "gh extension list *": "allow",
      "gh extension search *": "allow",
      "gh ext list *": "allow",
      "gh ext search *": "allow",
      "gh extensions list *": "allow",
      "gh attestation download *": "allow",
      "gh attestation trusted-root *": "allow",
      "gh attestation verify *": "allow",
      "gh at download *": "allow",
      "gh at trusted-root *": "allow",
      "gh at verify *": "allow",
      // 开发工具
      "ruff *": "allow",
      "rumdl *": "allow",
      "shellcheck *": "allow",
      // OpenCode 相关
      "opencode *": "allow",
      "npx skills find *": "allow",
      // 浏览器自动化
      "playwright-cli *": "allow",
      "agent-browser *": "allow",
    },
  },
  "plugin": [
    "oh-my-openagent@3.17.1"
  ],
}
